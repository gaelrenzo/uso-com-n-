# Llaves de API y Tokens Sensibles (UCN)
# Carga automaticamente como variables de entorno.
# NUNCA agregues este archivo (sin .example) al control de versiones!

# Tokens de GitHub
GITHUB_TOKEN=your_github_token_here

# API Keys para Agentes de IA
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Configuracion de Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Rutas personalizadas (opcional, sobrescribe defaults)
UCN_NOTES_DIR=/storage/emulated/0/universida-datos/notas
UCN_CLASE_DIR=/storage/emulated/0/universida-datos
UCN_INFORMES_DIR=/storage/emulated/0/universida-datos/informes
