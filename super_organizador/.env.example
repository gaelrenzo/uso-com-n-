# ============================================
# SUPER ORGANIZADOR - Variables de entorno
# ============================================
# Copia este archivo como .env y completa tus claves
# USO: python main.py --path "X:\CualquierUnidad"
#   (el --path es la forma RECOMENDADA de especificar la ruta)

# --- Ruta raíz (opcional, sobreescribe config.yaml) ---
# ROOT_PATH="J:\Mi unidad"

# --- Proveedor de IA (necesario para opción 11 y 5) ---
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini

# --- Claves API (solo si usas IA) ---
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=...
# OLLAMA_URL=http://localhost:11434
# LM_STUDIO_URL=http://localhost:1234